# ==========================================
# Application Configuration
# ==========================================

# Port the NestJS application server will listen on (exposed to host)
PORT=3000

# Node execution environment mode (development | production)
NODE_ENV=production

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================

# Database host name (set to 'db' when running within Docker, or 'localhost' for local host runs)
DATABASE_HOST=db

# Port PostgreSQL database service listens on (default is 5432)
DATABASE_PORT=5432

# Username used to connect to the PostgreSQL database
DATABASE_USER=postgres

# Password associated with the database user (change this to a secure string in production!)
DATABASE_PASSWORD=your_secure_password

# Database catalog name
DATABASE_NAME=booking_platform

# Full Prisma datasource connection URL string
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public"

# ==========================================
# Authentication Secrets (JWT tokens)
# ==========================================

# Secret key used to sign and verify short-lived JSON Web Access Tokens (must be cryptographically strong)
JWT_SECRET=super_secret_access_key

# Secret key used to sign and verify long-lived JSON Web Refresh Tokens
JWT_REFRESH_SECRET=super_secret_refresh_key

# ==========================================
# Docker Hub Image Configuration
# ==========================================

# Docker Hub Username / Registry namespace where the compiled image is hosted
DOCKER_REGISTRY_USER=mircofernando
