// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema


//The moduleFormat configuration is required because Prisma v7
//ships as an ES module by default, which does not work with NestJS's
//CommonJS setup. Setting moduleFormat to cjs forces Prisma to generate
//a CommonJS module instead of ESM.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// MODELS
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  refreshTokenHash String?   @map("refresh_token_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Back-relation (Fixes the missing relation error)
  services     Service[]

  @@map("users")
}

model Service {
  id          String    @id @default(uuid()) @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  title       String
  description String?
  duration    Int
  price       Decimal   @db.Decimal(10, 2) // Precision setup for currency
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy   User      @relation(fields: [createdById], references: [id])
  bookings    Booking[]

  @@map("services")
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  serviceId     String        @map("service_id") @db.Uuid
  customerName  String        @map("customer_name")
  customerEmail String        @map("customer_email")
  customerPhone String        @map("customer_phone")
  bookingDate   DateTime      @map("booking_date") @db.Date
  bookingTime   DateTime      @map("booking_time") @db.Time
  status        BookingStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  service       Service       @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, bookingDate, bookingTime]) // Prevents duplicate bookings for the same service,date, Time
  @@map("bookings")
}
